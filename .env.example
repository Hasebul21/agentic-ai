# Copy this file to .env and fill in your keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...   # optional
TAVILY_API_KEY=...              # optional — for web search tool
LANGSMITH_API_KEY=...           # optional — for tracing with LangSmith
LANGSMITH_TRACING=true
LANGCHAIN_PROJECT=agentic-ai-practice
GEMINI_API_KEY=...              # optional — for Gemini experiments
GROQ_API_KEY=...                # optional — for Groq experiments
OPENROUTER_API_KEY=...          # optional — for OpenRouter experiments

# Postgres
DATABASE_URL=postgresql://agentic:agentic123@localhost:5432/agentic_ai